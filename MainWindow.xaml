<Window x:Class="DemoGUI_Preferences.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoGUI_Preferences"
        mc:Ignorable="d"
        Title="Preferences" Height="250" Width="800">
    <Grid Margin="-1,0,1,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="227*"/>
        </Grid.RowDefinitions>
        <Label Content="Arrival date " HorizontalAlignment="Left" Margin="38,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.605,0.039" Width="134" Height="33" Grid.Row="1"/>
        <Label Content="Departure date " HorizontalAlignment="Left" Margin="288,11,0,0" VerticalAlignment="Top" Grid.Row="1" Height="34" Width="108"/>
        <Label Content="Number of  children" HorizontalAlignment="Left" Margin="288,116,0,0" VerticalAlignment="Top" Grid.Row="1" Height="33" Width="134"/>
        <Label Content="Filter" HorizontalAlignment="Left" Margin="490,11,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.941,-0.112" Grid.Row="1" Height="34" Width="41"/>
        <TextBox x:Name ="NumberOfChildren" HorizontalAlignment="Left" Margin="288,168,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="134" TextChanged="NumberOfChildren_TextChanged" Grid.Row="1" Height="23"/>
        <Label Content="Number of adults " HorizontalAlignment="Left" Margin="38,122,0,0" VerticalAlignment="Top" Grid.Row="1" Height="33" Width="122"/>
        <TextBox x:Name ="NumberOfAdults"  HorizontalAlignment="Left" Margin="38,168,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="138" Grid.Row="1" Height="23" TextChanged="NumberOfAdults_TextChanged"/>
        <Button x:Name ="ButtonArrivalDate" Content="Sekect date " Margin="38,48,0,0" Grid.Row="1" Height="24" Width="138" Click="ButtonArrivalDate_Click" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Button x:Name ="ButtonDepartureDate" Content="Select date" Margin="288,48,0,0" Grid.Row="1" Height="24"  Width="138" Click="ButtonDepartureDate_Click" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Button x:Name="Close" Content="Close" HorizontalAlignment="Left" Margin="490,167,0,0" VerticalAlignment="Top" Height="24" Width="270" Click="Close_Click" Grid.Row="1"/>
        <Menu x:Name="Filter" Margin="490,48,0,0" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Height="107" Width="270">
            <Menu.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </Menu.ItemsPanel>
        </Menu>
    </Grid>
</Window>
